<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />

    <application
        android:name=".BookWriterApp"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.BookWriter">

        <activity
            android:name=".ui.book.MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity android:name=".ui.book.BookDetailActivity" android:theme="@style/Theme.BookWriter" />
        <activity android:name=".ui.chapter.ChapterEditActivity" android:theme="@style/Theme.BookWriter" />
        <activity android:name=".ui.character.CharacterEditActivity" android:theme="@style/Theme.BookWriter" />
        <activity android:name=".ui.worldbuilding.WorldbuildingEditActivity" android:theme="@style/Theme.BookWriter" />
        <activity android:name=".ui.timer.TimerActivity" android:theme="@style/Theme.BookWriter" />
        <activity android:name=".ui.about.AboutActivity" android:theme="@style/Theme.BookWriter" />
        <activity android:name=".ui.export.ExportActivity" android:theme="@style/Theme.BookWriter" />

    </application>
</manifest>